{
  "name": "indieboost-backend",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "indieboost-db",
      "database_id": "indieboost-db-id",
      "migrations_dir": "migrations"
    }
  ],
  "observability": {
    "enabled": true
  }
}
