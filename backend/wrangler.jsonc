{
  "name": "indieboost-backend",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "indieboost-db",
      "database_id": "bf7dd750-eaaa-422c-959f-82765b318339",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "GOOGLE_REDIRECT_URI": "https://indie-boost.vercel.app/api/auth/google/callback"
  },
  "observability": {
    "enabled": true
  }
}
